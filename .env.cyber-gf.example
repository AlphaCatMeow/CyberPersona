# CyberPersona 配置示例
# 复制为 .env.cyber-gf 并填入真实值

# ========== Xiaomi MiMo TTS ==========
XIAOMI_BASE_URL=your_mimo_base_url_here
XIAOMI_API_KEY=your_x...here
XIAOMI_TTS_MODEL=mimo-v2.5-tts
XIAOMI_TTS_VOICE=茉莉
XIAOMI_TTS_FORMAT=mp3

# ========== Image API ==========
IMAGE_API_KEY=your_i...here
IMAGE_API_BASE=your_image_api_base_here

# ========== Local paths ==========
# 默认值（通常不需要修改）
# CYBER_GF_STATE_FILE=./data/state.json
# CYBER_GF_HISTORY_FILE=./data/history.json
# CYBER_GF_TTS_OUTPUT_DIR=./data/tts
# CYBER_GF_IMAGE_OUTPUT_DIR=./data/img

# ========== Debug ==========
CYBER_GF_DEBUG=false
CYBER_GF_DEBUG_TTS=false
